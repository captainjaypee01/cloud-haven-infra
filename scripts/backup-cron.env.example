# Copy to a path outside git (e.g. /root/.config/cloud-haven-backup.env) and fill in values.
# Cron example:
#   0 3 * * * set -a; . /root/.config/cloud-haven-backup.env; set +a; cd /opt/code/cloud-haven-infra && ./scripts/backup-and-upload-gdrive.sh both >> /var/log/cloud-haven-backup.log 2>&1
#
# rclone: run `rclone config` once on the droplet; tokens live in ~/.config/rclone/

RCLONE_DEST=gdrive:CloudHaven/backups

# If backups should go into one specific Drive folder from a link like:
#   https://drive.google.com/drive/folders/FOLDER_ID_HERE
# use the folder ID and either set root_folder_id in `rclone config`, or:
# RCLONE_DEST=gdrive:
# RCLONE_FLAGS=--drive-root-folder-id FOLDER_ID_HERE
# Multiple flags (example): RCLONE_FLAGS="--drive-root-folder-id FOLDER_ID_HERE --bwlimit 8M"

# Optional: limit bandwidth (when not using drive-root-folder-id above)
# RCLONE_FLAGS=--bwlimit 8M
# Optional: upload every matching file (migration); default is only recent files
# GDRIVE_UPLOAD_ALL=0
# GDRIVE_UPLOAD_MAX_AGE_MINUTES=1800
